# Configuration file for AI Grading System
# This file contains non-sensitive configuration settings
# API keys should be stored in .env file

# Vertex AI Configuration
vertex_ai:
  use_vertexai: true

# Logging Configuration
logging:
  # Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
  # - DEBUG: Most verbose, shows all operations including cache checks, event processing
  # - INFO: Standard logging, shows important operations and cache hits/misses
  # - WARNING: Only warnings and errors
  # - ERROR: Only errors
  level: INFO

# Caching Configuration
caching:
  # Master cache control - disables ALL agent caching when false
  enabled: true
  
  # Individual agent cache controls (only apply when enabled=true)
  agents:
    ocr: true
    grading: true
    moderation: true
    marking_scheme: true
    annotation: true
    analytics: true

# Model Configuration
# Controls which AI models are used for each agent type
# Default models are optimized for each task
models:
  # OCR Agent - Text extraction from images
  ocr: gemini-2.5-flash
  
  # Grading Agent - Evaluating student answers
  grading: gemini-3-flash-preview
  
  # Moderation Agent - Ensuring grading consistency
  moderation: gemini-3-pro-preview
  
  # Marking Scheme Agent - Extracting and verifying marking schemes
  marking_scheme: gemini-3-flash-preview
  
  # Annotation Agent - Extracting bounding boxes from images
  annotation: gemini-3-flash-preview
  
  # Analytics Agent - Generating reports and insights
  analytics: gemini-3-flash-preview
  
  # Analytics Image Agent - Generating infographic images
  analytics_image: gemini-3-pro-image-preview
