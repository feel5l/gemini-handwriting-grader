# Vertex AI Express Mode API Key (https://aistudio.google.com/apikey)
# Get your API key from: https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Agent Log Level Configuration
# Controls the verbosity of agent logging output
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# - DEBUG: Most verbose, shows all operations including cache checks, event processing
# - INFO: Standard logging, shows important operations and cache hits/misses
# - WARNING: Only warnings and errors
# - ERROR: Only errors
AGENT_LOG_LEVEL=INFO

# Agent Caching Configuration
# Controls whether caching is enabled for each agent type
# Valid values: TRUE, FALSE
# Default: TRUE (caching enabled)
# Set to FALSE to disable caching for specific agents (useful for debugging or testing)

# Master cache control - disables ALL agent caching when FALSE
AGENT_CACHE_ENABLED=TRUE

# Individual agent cache controls (only apply when AGENT_CACHE_ENABLED=TRUE)
AGENT_CACHE_OCR=TRUE
AGENT_CACHE_GRADING=TRUE
AGENT_CACHE_MODERATION=TRUE
AGENT_CACHE_MARKING_SCHEME=TRUE
AGENT_CACHE_ANNOTATION=TRUE
AGENT_CACHE_ANALYTICS=TRUE